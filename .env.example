# --- MySQL ---
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+pymysql://huizen:secret@127.0.0.1:3306/huizen_zoeker

# --- SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=Huizen Zoeker <user@example.com>
SMTP_USE_TLS=true

# --- Flask web UI ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_SECRET_KEY=change-me-to-something-random
# Public base URL used in email links (so source-site links resolve fine, but
# any "view in app" links need the base). Local-only by default.
APP_BASE_URL=http://127.0.0.1:5000

# --- Scraper ---
# Comma-separated HH:MM (24h, local time) — one full scrape fires per slot.
SCRAPE_TIMES=09:00,12:00,17:00,20:00
# Run once immediately on app startup
SCRAPE_ON_STARTUP=true
# Auto-refresh funda cookies before each scrape (opens default browser briefly)
AUTO_REFRESH_FUNDA_COOKIES=true
# Minutes before each SCRAPE_TIMES slot at which to refresh cookies
FUNDA_COOKIE_REFRESH_LEAD_MINUTES=30
# Headless browser (set to false to debug visually)
HEADLESS=true
# Per-scraper timeout (seconds)
SCRAPE_TIMEOUT=45
LOG_LEVEL=INFO
